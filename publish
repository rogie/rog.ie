#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
FIGUI3_REPO_URL="https://github.com/rogie/figui3.git"
FIGUI3_TMP_DIR="/tmp/figui3-publish-temp"
FIGUI3_PROPKIT_DIR="$FIGUI3_TMP_DIR/propkit"
FIGUI3_DIST_DIR="$FIGUI3_PROPKIT_DIR/dist"
FIGUI3_DIST_INDEX="$FIGUI3_DIST_DIR/index.html"
TARGET_DIR="$REPO_ROOT/propkit"
TARGET_FILE="$TARGET_DIR/index.html"
TARGET_ASSETS_DIR="$TARGET_DIR/assets"
STATE_FILE="/tmp/new-rogie-publish-state.json"

usage() {
  cat <<'EOF'
Usage:
  ./publish             Build latest figui3 propkit app and sync dist output into this repo.
  ./publish sync        Same as default.
  ./publish confirm     Git add/commit/push after you visually verify the page.

Workflow:
  1) Run ./publish
  2) Verify the updated propkit page locally
  3) Run ./publish confirm
EOF
}

ensure_clean_prereqs() {
  if ! command -v git >/dev/null 2>&1; then
    echo "Error: git is required."
    exit 1
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    echo "Error: python3 is required."
    exit 1
  fi
  if ! command -v npm >/dev/null 2>&1; then
    echo "Error: npm is required."
    exit 1
  fi
  if ! command -v npx >/dev/null 2>&1; then
    echo "Error: npx is required."
    exit 1
  fi
}

sync_figui3() {
  if [[ -d "$FIGUI3_TMP_DIR/.git" ]]; then
    git -C "$FIGUI3_TMP_DIR" fetch origin
    git -C "$FIGUI3_TMP_DIR" reset --hard origin/HEAD
  else
    rm -rf "$FIGUI3_TMP_DIR"
    git clone --depth 1 "$FIGUI3_REPO_URL" "$FIGUI3_TMP_DIR"
  fi
}

build_propkit_dist() {
  if [[ ! -f "$FIGUI3_PROPKIT_DIR/package.json" ]]; then
    echo "Error: figui3 propkit package not found: $FIGUI3_PROPKIT_DIR/package.json"
    exit 1
  fi

  if [[ ! -d "$FIGUI3_PROPKIT_DIR/node_modules" ]]; then
    npm ci --prefix "$FIGUI3_PROPKIT_DIR"
  fi

  (
    cd "$FIGUI3_PROPKIT_DIR"
    npx vite build --outDir dist
  )

  if [[ ! -f "$FIGUI3_DIST_INDEX" ]]; then
    echo "Error: missing dist index after build: $FIGUI3_DIST_INDEX"
    exit 1
  fi
  if [[ ! -d "$FIGUI3_DIST_DIR/assets" ]]; then
    echo "Error: missing dist assets after build: $FIGUI3_DIST_DIR/assets"
    exit 1
  fi
}

sync_propkit_dist() {
  if [[ ! -d "$TARGET_DIR" ]]; then
    echo "Error: target directory not found: $TARGET_DIR"
    exit 1
  fi

  local figui3_commit
  figui3_commit="$(git -C "$FIGUI3_TMP_DIR" rev-parse --short HEAD)"

  python3 - "$FIGUI3_DIST_INDEX" "$TARGET_FILE" "$STATE_FILE" "$figui3_commit" <<'PY'
import json
import re
import sys
from pathlib import Path

src_path = Path(sys.argv[1])
dst_path = Path(sys.argv[2])
state_path = Path(sys.argv[3])
figui3_commit = sys.argv[4]

updated_html = src_path.read_text(encoding="utf-8")
source_used = src_path

# Vite emits absolute /assets paths by default; rewrite for /propkit hosting.
updated_html = re.sub(r'(["\'])/assets/', r"\1./assets/", updated_html)

dst_path.write_text(updated_html, encoding="utf-8")

state = {
    "figui3_commit": figui3_commit,
    "target_file": str(dst_path),
    "source_file": str(source_used),
    "mode": "react-dist",
}
state_path.write_text(json.dumps(state), encoding="utf-8")

print(f"Updated {dst_path}")
print(f"Synced from figui3 commit {figui3_commit}")
print(f"Source file used: {source_used}")
PY

  rm -rf "$TARGET_ASSETS_DIR"
  cp -R "$FIGUI3_DIST_DIR/assets" "$TARGET_ASSETS_DIR"
  echo "Synced assets into: $TARGET_ASSETS_DIR"
}

confirm_publish() {
  if [[ ! -f "$STATE_FILE" ]]; then
    echo "Error: no pending publish state found."
    echo "Run ./publish first, verify visually, then run ./publish confirm."
    exit 1
  fi

  local figui3_commit
  figui3_commit="$(python3 - "$STATE_FILE" <<'PY'
import json, sys
from pathlib import Path
state = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
print(state.get("figui3_commit", ""))
PY
)"

  git -C "$REPO_ROOT" add -A
  git -C "$REPO_ROOT" commit -m "$(cat <<EOF
publish: sync propkit from figui3

Update PropKit from figui3 React dist build (commit ${figui3_commit}) and sync bundled assets for production.
EOF
)"
  git -C "$REPO_ROOT" push

  rm -f "$STATE_FILE"
  echo "Publish complete."
}

main() {
  ensure_clean_prereqs

  local command="${1:-sync}"
  case "$command" in
    sync)
      sync_figui3
      build_propkit_dist
      sync_propkit_dist
      echo ""
      echo "Please verify the PropKit page now."
      echo "If it looks good, run: ./publish confirm"
      ;;
    confirm)
      confirm_publish
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      echo "Unknown command: $command"
      echo ""
      usage
      exit 1
      ;;
  esac
}

main "$@"
