#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"
FIGUI3_REPO_URL="https://github.com/rogie/figui3.git"
FIGUI3_TMP_DIR="/tmp/figui3-publish-temp"
FIGUI3_DIST_ROOT="$FIGUI3_TMP_DIR/dist"
APPS=("propkit" "figui3")
STATE_FILE="/tmp/new-rogie-publish-state.json"

usage() {
  cat <<'EOF'
Usage:
  ./publish             Build latest figui3 pages and sync dist output into this repo.
  ./publish sync        Same as default.
  ./publish confirm     Git add/commit/push after you visually verify the page.

Workflow:
  1) Run ./publish
  2) Verify the updated /propkit and /figui3 pages locally
  3) Run ./publish confirm
EOF
}

ensure_clean_prereqs() {
  if ! command -v git >/dev/null 2>&1; then
    echo "Error: git is required."
    exit 1
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    echo "Error: python3 is required."
    exit 1
  fi
  if ! command -v npm >/dev/null 2>&1; then
    echo "Error: npm is required."
    exit 1
  fi
  if ! command -v npx >/dev/null 2>&1; then
    echo "Error: npx is required."
    exit 1
  fi
}

sync_figui3() {
  if [[ -d "$FIGUI3_TMP_DIR/.git" ]]; then
    git -C "$FIGUI3_TMP_DIR" fetch origin
    git -C "$FIGUI3_TMP_DIR" reset --hard origin/HEAD
  else
    rm -rf "$FIGUI3_TMP_DIR"
    git clone --depth 1 "$FIGUI3_REPO_URL" "$FIGUI3_TMP_DIR"
  fi
}

detect_playground_dir() {
  if [[ -f "$FIGUI3_TMP_DIR/playground/package.json" ]]; then
    echo "$FIGUI3_TMP_DIR/playground"
    return 0
  fi
  if [[ -f "$FIGUI3_TMP_DIR/propkit/package.json" ]]; then
    echo "$FIGUI3_TMP_DIR/propkit"
    return 0
  fi
  echo ""
  return 1
}

build_figui3_dist_outputs() {
  local playground_dir
  playground_dir="$(detect_playground_dir || true)"
  if [[ -z "$playground_dir" ]]; then
    echo "Error: figui3 playground package not found (checked /playground and /propkit)."
    exit 1
  fi

  if [[ ! -d "$playground_dir/node_modules" ]]; then
    npm ci --prefix "$playground_dir"
  fi

  (
    cd "$playground_dir"
    rm -rf "$FIGUI3_DIST_ROOT/propkit" "$FIGUI3_DIST_ROOT/figui3"
    npx vite build --base /propkit/ --outDir "$FIGUI3_DIST_ROOT/propkit" --emptyOutDir
    npx vite build --base /figui3/ --outDir "$FIGUI3_DIST_ROOT/figui3" --emptyOutDir
  )

  for app in "${APPS[@]}"; do
    if [[ ! -f "$FIGUI3_DIST_ROOT/$app/index.html" ]]; then
      echo "Error: missing dist index after build: $FIGUI3_DIST_ROOT/$app/index.html"
      exit 1
    fi
    if [[ ! -d "$FIGUI3_DIST_ROOT/$app/assets" ]]; then
      echo "Error: missing dist assets after build: $FIGUI3_DIST_ROOT/$app/assets"
      exit 1
    fi
  done
}

sync_one_app_dist() {
  local app="$1"
  local source_dir="$FIGUI3_DIST_ROOT/$app"
  local source_index="$source_dir/index.html"
  local target_dir="$REPO_ROOT/$app"
  local target_file="$target_dir/index.html"
  local target_assets_dir="$target_dir/assets"

  mkdir -p "$target_dir"

  python3 - "$source_index" "$target_file" "$app" <<'PY'
import re
import sys
from pathlib import Path

src_path = Path(sys.argv[1])
dst_path = Path(sys.argv[2])
app_name = sys.argv[3]

updated_html = src_path.read_text(encoding="utf-8")
# Vite emits absolute /assets paths by default; rewrite for /<app> hosting.
updated_html = re.sub(r'(["\'])/assets/', r"\1./assets/", updated_html)
updated_html = re.sub(r'(["\'])/(?:figui3|propkit)/assets/', r"\1./assets/", updated_html)

# figui3's static demo index can reference root files directly (fig.css/fig.js).
# Normalize those to /<app>/assets so subpath hosting works reliably.
if app_name == "figui3":
    for filename in ("fig.css", "fig.js", "components.css", "base.css"):
        pattern = rf'(["\'])(?:/|\.?/)?{re.escape(filename)}\1'
        replacement = rf'\1./assets/{filename}\1'
        updated_html = re.sub(pattern, replacement, updated_html)

dst_path.write_text(updated_html, encoding="utf-8")

print(f"Updated {dst_path}")
print(f"Synced app: {app_name}")
print(f"Source file used: {src_path}")
PY

  rm -rf "$target_assets_dir"
  cp -R "$source_dir/assets" "$target_assets_dir"
  echo "Synced assets into: $target_assets_dir"
}

sync_all_dist() {
  local figui3_commit
  figui3_commit="$(git -C "$FIGUI3_TMP_DIR" rev-parse --short HEAD)"

  for app in "${APPS[@]}"; do
    sync_one_app_dist "$app"
  done

  python3 - "$STATE_FILE" "$figui3_commit" <<'PY'
import json
import sys
from pathlib import Path

state_path = Path(sys.argv[1])
figui3_commit = sys.argv[2]

state = {
    "figui3_commit": figui3_commit,
    "apps": ["propkit", "figui3"],
    "mode": "multi-react-dist",
}
state_path.write_text(json.dumps(state), encoding="utf-8")
print(f"Synced from figui3 commit {figui3_commit}")
PY
}

confirm_publish() {
  if [[ ! -f "$STATE_FILE" ]]; then
    echo "Error: no pending publish state found."
    echo "Run ./publish first, verify visually, then run ./publish confirm."
    exit 1
  fi

  local figui3_commit
  figui3_commit="$(python3 - "$STATE_FILE" <<'PY'
import json, sys
from pathlib import Path
state = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
print(state.get("figui3_commit", ""))
PY
)"

  git -C "$REPO_ROOT" add -A
  git -C "$REPO_ROOT" commit -m "$(cat <<EOF
publish: sync figui3 and propkit from figui3

Update figui3 and PropKit pages from figui3 dist builds (commit ${figui3_commit}) and sync bundled assets for production.
EOF
)"
  git -C "$REPO_ROOT" push

  rm -f "$STATE_FILE"
  echo "Publish complete."
}

main() {
  ensure_clean_prereqs

  local command="${1:-sync}"
  case "$command" in
    sync)
      sync_figui3
      build_figui3_dist_outputs
      sync_all_dist
      echo ""
      echo "Please verify these pages now:"
      echo "  - /propkit"
      echo "  - /figui3"
      echo "If it looks good, run: ./publish confirm"
      ;;
    confirm)
      confirm_publish
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      echo "Unknown command: $command"
      echo ""
      usage
      exit 1
      ;;
  esac
}

main "$@"
